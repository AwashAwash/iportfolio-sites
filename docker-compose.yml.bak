version: '4.8'

services:
  prometheus:
    image: prom/prometheus:v2.51.2
    container_name: prometheus
    restart: unless-stopped
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus_data:/prometheus
    ports:
      - "9090:9090"
    networks:
      - monitor-net

  node-exporter:
    image: prom/node-exporter:v1.8.2
    container_name: node-exporter
    restart: unless-stopped
    ports:
      - "9100:9100"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - '--path.procfs=/host/proc'
      - '--path.sysfs=/host/sys'
      - '--collector.filesystem.ignored-mount-points=^/(sys|proc|dev|host|etc)($$|/)'
    networks:
      - monitor-net

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:v0.49.1
    container_name: cadvisor
    restart: unless-stopped
    ports:
      - "8080:8080"
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:rw
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
    networks:
      - monitor-net

  grafana:
    image: grafana/grafana:11.2.2
    container_name: grafana
    restart: unless-stopped
    ports:
      - "3000:3000"
    volumes:
      - grafana_data:/var/lib/grafana
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin123 # CHANGE THIS IMMEDIATELY!
      # SMTP example (Gmail) - update with real values
      - GF_SMTP_ENABLED=true
      - GF_SMTP_HOST=smtp.gmail.com:587
      - GF_SMTP_USER=maskeyawash@gmail.com
      - GF_SMTP_PASSWORD=etexxxvawmsbxbfw
      - GF_SMTP_FROM_ADDRESS=makeyawash@gmail.com
      - GF_SMTP_FROM_NAME=Grafana VPS Alerts
      - GF_SMTP_STARTTLS_POLICY=OpportunisticStartTLS
    networks:
      - monitor-net

  jenkins-exporter:
    image: prometheuscommunity/jenkins-exporter:latest
    container_name: jenkins-exporter
    restart: unless-stopped
    ports:
      - "9118:9118"
    environment:
      - JENKINS_URL=http://217.154.44.73:8081
      - JENKINS_USERNAME=awashawash
      - JENKINS_PASSWORD=hellO@404!!!
    networks:
      - monitor-net

networks:
  monitor-net:
    driver: bridge

volumes:
  prometheus_data:
  grafana_data:
